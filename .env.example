# Copy to .env and fill in. Never commit your real .env.

# Discord (bot token + your own user ID for DMs and self-DM capture)
DISCORD_BOT_TOKEN=
DISCORD_USER_ID=

# GitHub (personal access token, scope: repo)
GITHUB_TOKEN=
# Comma-separated list of repos the code-reviewer skill watches: owner/repo1,owner/repo2
GITHUB_ASSIGNMENT_REPOS=

# Outlook (deferred — only needed once university email is wired up)
# OUTLOOK_TENANT_ID=

# Google Calendar / Gmail use OAuth — place google_credentials.json at
# .claude/data/google_credentials.json. No env var needed.
# Claude CLI billing token (heartbeat reasoner) — place at
# .claude/data/claude-token.txt. No env var needed.

# Discord dashboard webhooks (one URL per channel).
# Fill these in as you create each channel + webhook in Discord's UI:
#   channel settings → Integrations → Webhooks → New Webhook → Copy URL
# Empty values are silently skipped, so you can wire channels incrementally.
# Slice 1 (start here):
DISCORD_HOOK_HEARTBEAT=
DISCORD_HOOK_ERRORS=
# Slice 2:
DISCORD_HOOK_INBOX=
# Slice 3 (forum channel):
DISCORD_HOOK_DEADLINES=
# Slice 4 (forum channel):
DISCORD_HOOK_LECTURES=
# Slice 5:
DISCORD_HOOK_PR_ACTIVITY=
DISCORD_HOOK_CODE_REVIEW=
# Slice 6 (single channel for morning_digest + evening_nudge + daily_digest;
# emoji prefix in the embed differentiates kind):
DISCORD_HOOK_DAILY=
# Slice 8 (#vesper chatbot channel):
DISCORD_HOOK_VESPER=
# Empty until upstream sources land:
DISCORD_HOOK_IDEAS=
DISCORD_HOOK_EMAIL_UNI=
DISCORD_HOOK_EMAIL_PERSONAL=

# Input pivot (2026-05-24): channels where the bot READS owner posts.
# Right-click each channel in Discord with Developer Mode on -> Copy Channel ID.
DISCORD_INBOX_CHANNEL_ID=
DISCORD_FINANCE_CHANNEL_ID=
DISCORD_VESPER_CHANNEL_ID=
