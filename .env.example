# Copy to .env and fill in values. Never commit your real .env.
# Empty values are silently skipped — features that need them are disabled.

# ── Vesper backend (FastAPI) ────────────────────────────────────────────────────
API_SECRET=                            # bearer secret for frontend -> API auth (required)
# CLAUDE_PROJECT_DIR and VAULT_PATH default to /workspace and
# /workspace/Dynamous/Memory inside the containers (set in docker-compose.yml);
# no need to set them in .env for the Docker stack.

# ── GitHub ─────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=                          # scope: repo
GITHUB_ASSIGNMENT_REPOS=              # owner/repo1,owner/repo2 (code-reviewer skill)

# ── Google ─────────────────────────────────────────────────────────────────────
# OAuth — place google_credentials.json at .claude/data/google_credentials.json
# No env var needed. Token is cached after first browser flow.
