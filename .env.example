# Vesper environment — copy to .env and fill in values. Never commit your real .env.
# Empty values are silently skipped; features that need them are disabled.

# ── Discord bot ──────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_USER_ID=

DISCORD_INBOX_CHANNEL_ID=
DISCORD_FINANCE_CHANNEL_ID=
DISCORD_VESPER_CHANNEL_ID=
DISCORD_HELP_CHANNEL_ID=

# ── Discord webhooks ─────────────────────────────────────────────────────────
DISCORD_HOOK_HEARTBEAT=
DISCORD_HOOK_ERRORS=
DISCORD_HOOK_DEADLINES=
DISCORD_HOOK_LECTURES=
DISCORD_HOOK_PR_ACTIVITY=
DISCORD_HOOK_DAILY=
DISCORD_HOOK_FEED=
DISCORD_HOOK_EMAIL_UNI=
DISCORD_HOOK_EMAIL_PERSONAL=

# ── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_ASSIGNMENT_REPOS=

# ── Google (OAuth) ───────────────────────────────────────────────────────────
# No env var — place google_credentials.json at .claude/data/google_credentials.json

# ── Microsoft Outlook ────────────────────────────────────────────────────────
OUTLOOK_TENANT_ID=
OUTLOOK_CLIENT_ID=

# ── AI services ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
