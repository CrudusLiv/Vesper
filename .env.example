# Copy to .env and fill in values. Never commit your real .env.
# Empty values are silently skipped — features that need them are disabled.

# ── Discord bot ─────────────────────────────────────────────────────────────────
# Developer Portal → Bot → Token
DISCORD_BOT_TOKEN=
# Your numeric Discord user ID: Settings → Advanced → Developer Mode → right-click yourself → Copy User ID
DISCORD_USER_ID=
# Right-click each channel → Copy Channel ID
DISCORD_INBOX_CHANNEL_ID=
DISCORD_FINANCE_CHANNEL_ID=
DISCORD_VESPER_CHANNEL_ID=
# Optional: override the slash-command help channel (defaults to DISCORD_INBOX_CHANNEL_ID)
# DISCORD_HELP_CHANNEL_ID=

# ── Discord webhooks (heartbeat outbound) ───────────────────────────────────────
# Each webhook posts to one channel. Channel Settings → Integrations → Webhooks → New Webhook → Copy URL.
DISCORD_HOOK_HEARTBEAT=
DISCORD_HOOK_ERRORS=
DISCORD_HOOK_DEADLINES=
DISCORD_HOOK_LECTURES=
DISCORD_HOOK_PR_ACTIVITY=
DISCORD_HOOK_DAILY=
DISCORD_HOOK_INBOX=
DISCORD_HOOK_IDEAS=
DISCORD_HOOK_EMAIL_UNI=
DISCORD_HOOK_EMAIL_PERSONAL=

# ── GitHub ─────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=                          # scope: repo
GITHUB_ASSIGNMENT_REPOS=              # owner/repo1,owner/repo2 (code-reviewer skill)

# ── Google ─────────────────────────────────────────────────────────────────────
# OAuth — place google_credentials.json at .claude/data/google_credentials.json
# No env var needed. Token is cached after first browser flow.

# ── Microsoft Outlook (Graph API) ──────────────────────────────────────────────
# Azure Portal → App registrations → your app → Overview
OUTLOOK_TENANT_ID=   # Directory (tenant) ID
OUTLOOK_CLIENT_ID=   # Application (client) ID
# First-time auth: py query.py outlook auth

# ── AI services ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                       # get a key at console.anthropic.com
# ANTHROPIC_MODEL=claude-opus-4-8        # default model
# ANTHROPIC_TIMEOUT=120                  # request timeout in seconds
