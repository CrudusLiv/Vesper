# Vesper environment — copy to .env and fill in values. Never commit your real .env.
# Empty values are silently skipped; features that need them are disabled.

# ── Google (OAuth) ───────────────────────────────────────────────────────────
# Google Cloud Console -> Credentials -> OAuth Desktop client -> download JSON
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_ASSIGNMENT_REPOS=

# ── Microsoft Outlook ────────────────────────────────────────────────────────
OUTLOOK_TENANT_ID=
OUTLOOK_CLIENT_ID=

# ── Voice assistant ───────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ── Claude / auth ─────────────────────────────────────────────────────────────
CLAUDE_CODE_OAUTH_TOKEN=
DASHBOARD_PASSWORD=
