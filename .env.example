# Copy to .env and fill in. Never commit your real .env.

# Discord (bot token + your own user ID for DMs and self-DM capture)
DISCORD_BOT_TOKEN=
DISCORD_USER_ID=

# GitHub (personal access token, scope: repo)
GITHUB_TOKEN=
# Comma-separated list of repos the code-reviewer skill watches: owner/repo1,owner/repo2
GITHUB_ASSIGNMENT_REPOS=

# Outlook (deferred — only needed once university email is wired up)
# OUTLOOK_TENANT_ID=

# Google Calendar / Gmail use OAuth — place google_credentials.json at
# .claude/data/google_credentials.json. No env var needed.
# Claude CLI billing token (heartbeat reasoner) — place at
# .claude/data/claude-token.txt. No env var needed.
