# Copy to .env and fill in values. Never commit your real .env.
# Empty values are silently skipped — features that need them are disabled.

# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_USER_ID=

# ── GitHub ─────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=                          # scope: repo
GITHUB_ASSIGNMENT_REPOS=              # owner/repo1,owner/repo2 (code-reviewer skill)

# ── Google ─────────────────────────────────────────────────────────────────────
# OAuth — place google_credentials.json at .claude/data/google_credentials.json
# No env var needed. Token is cached after first browser flow.

# ── Discord dashboard webhooks ─────────────────────────────────────────────────
# Channel settings → Integrations → Webhooks → New Webhook → Copy URL

DISCORD_HOOK_HEARTBEAT=
DISCORD_HOOK_ERRORS=

DISCORD_HOOK_INBOX=
DISCORD_HOOK_DEADLINES=               # must be a forum channel
DISCORD_HOOK_LECTURES=                # must be a forum channel

DISCORD_HOOK_PR_ACTIVITY=
DISCORD_HOOK_CODE_REVIEW=

DISCORD_HOOK_DAILY=                   # morning_digest + evening_nudge + daily_digest
DISCORD_HOOK_VESPER=                  # LLM chat replies

DISCORD_HOOK_IDEAS=
DISCORD_HOOK_EMAIL_UNI=
DISCORD_HOOK_EMAIL_PERSONAL=

# ── Discord input channels ─────────────────────────────────────────────────────
# Right-click channel (Developer Mode on) → Copy Channel ID

DISCORD_INBOX_CHANNEL_ID=
DISCORD_FINANCE_CHANNEL_ID=
DISCORD_VESPER_CHANNEL_ID=

# Channel to pin the /help reference in. Optional — defaults to
# DISCORD_INBOX_CHANNEL_ID when unset.
DISCORD_HELP_CHANNEL_ID=
